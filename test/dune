; The fast suite (FP replays/fuzz + single-instruction CPU lockstep + the lib's inline
; tests) runs on `dune runtest` in a few seconds. The heavyweight boot-handoff checkpoint
; (~22 s — it boots the real Oberon disk to the OS handoff) is OPT-IN, like the RTL co-sim
; (AGENT.md §6); run it with:  dune build @boot_checkpoint

(tests
 (names test_fp_adder test_fp_multiplier test_fp_divider test_cpu_lockstep)
 (modules
  fp_replay
  test_fp_adder
  test_fp_multiplier
  test_fp_divider
  test_cpu_lockstep)
 (libraries risc5 oracle hardcaml hardcaml_waveterm qcheck-core)
 ; Phase 3b: the frozen FP vectors (vendored, data-only) feed test_fp_adder's replay.
 (deps ../vendor/oberon-risc-emu-ocaml/test/data/fp_vectors.txt)
 (preprocess
  (pps ppx_hardcaml)))

; Phase 5: boot-handoff checkpoint (AGENT.md §6 layer 5). Built by @check so it can't rot,
; but run only on demand (it boots the real disk image for millions of interpreter cycles).

(executable
 (name test_boot_checkpoint)
 (modules test_boot_checkpoint)
 (libraries risc5 oracle hardcaml))

(rule
 (alias boot_checkpoint)
 (deps ../vendor/oberon-risc-emu-ocaml/DiskImage/Oberon-2020-08-18.dsk)
 (action
  (run ./test_boot_checkpoint.exe)))
