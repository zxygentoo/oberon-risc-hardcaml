# OCaml / dune build artifacts
_build/
*.install
.merlin
*.merlin

# Local opam switch
_opam/

# Original Project Oberon sources (Verilog, PDFs, boot ROM): not vendored (licensing). The
# co-sim fetches the reference Verilog on demand into test/_po/ and checksum-verifies it; see
# test/rtl-sources.txt. The _ prefix marks it local/generated, like _build.
/test/_po/

# Test scratch: Verilator obj_dirs, dumped port traces, the downloaded RTL zip, yosys/z3
# intermediates. Generated on demand by the opt-in cosim/formal runners; safe to delete.
/test/_work/

# Board (Phase 7) generated/build artifacts: the emitted soc_board.v and the Vivado runs +
# bitstream, keyed by board under these two trees (regenerate via gen_verilog.sh / build.tcl).
# One entry each covers all boards; everything else under boards/ is tracked source.
/boards/_generated/
/boards/_build/

# Vivado batch-run scratch, dropped in whatever directory vivado is launched from (the repo
# root, or boards/<target>/ when build/program/flash are run from there) — un-anchored so it
# is ignored at any depth, keeping boards/<target>/ pure tracked source either way.
.Xil/
clockInfo.txt
vivado*.jou
vivado*.log

# Editor / OS cruft
*~
*.swp
*.swo
.DS_Store
.vscode/
.idea/
